# ===========================================
# 洞察捕捉 (Insight) 配置文件
# 使用前请：
#   1. 复制此文件为 .env
#   2. 把下面的占位符改成你自己的值
# ===========================================

# 存储方式: sqlite（本地文件，零配置）或 supabase（云同步）
STORAGE_TYPE=sqlite

# SQLite 数据库文件路径（使用 SQLite 时生效）
DB_PATH=./data/insights.db

# ⬇️ 以下只有使用 Supabase 时才需要填 ⬇️
# 去 supabase.com 注册 → 创建项目 → Settings → API
SUPABASE_URL=https://换成你自己的.supabase.co
SUPABASE_ANON_KEY=换成你自己的anon_key
SUPABASE_TABLE=insights

# Web 面板端口
PORT=3456
